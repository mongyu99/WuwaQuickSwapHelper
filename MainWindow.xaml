<Window x:Class="WuwaQuickSwapHelper.MainWindow"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WuwaQuickSwapHelper"
        Width="600"
        Height="200">

	<Grid Margin="20">

		<Grid.RenderTransform>
			<TranslateTransform x:Name="ShakeTransform"/>
		</Grid.RenderTransform>


		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>


		<!-- 현재 입력 -->
		<StackPanel Grid.Row="0">

			<TextBlock
				Text="현재 입력"
				FontSize="16"/>

			<TextBlock
				x:Name="CurrentInputText"
				Text="-"
				FontSize="35"
				FontWeight="Bold"/>

		</StackPanel>



		<!-- 다음 입력 리스트 -->
		<ItemsControl
			x:Name="NextInputList"
			Grid.Row="2">


			<ItemsControl.ItemsPanel>

				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal"/>
				</ItemsPanelTemplate>

			</ItemsControl.ItemsPanel>



			<ItemsControl.ItemTemplate>

				<DataTemplate>

					<Border
						Margin="3"
						Padding="8"
						CornerRadius="6"
						Background="#333333">

						<TextBlock
							Text="{Binding}"
							FontSize="20"
							FontWeight="Bold"/>

					</Border>

				</DataTemplate>

			</ItemsControl.ItemTemplate>


		</ItemsControl>


	</Grid>

</Window>