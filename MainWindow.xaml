<Window x:Class="WuwaQuickSwapHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WuwaQuickSwapHelper"
        Height="300"
        Width="600">

	<Grid Margin="20">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel>

			<TextBlock
				Text="현재 입력"
				FontWeight="Bold"
				FontSize="18"/>

			<TextBlock
				x:Name="CurrentInputText"
				FontSize="40"
				Text="-"/>

		</StackPanel>

		<ListBox
			Grid.Row="2"
			x:Name="NextInputList"
			FontSize="28"/>
	</Grid>

</Window>