<Window x:Class="WuwaQuickSwapHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WuwaQuickSwapHelper.Converters"
        Title="WuwaQuickSwapHelper"
        Width="700"
        Height="300"
		WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
		Topmost="True"
        ShowInTaskbar="True">

    <Window.Resources>
        <!-- 현재 입력 키 크기 -->
        <conv:CurrentSizeConverter x:Key="CurrentSizeConverter"/>
        <!-- 현재 입력 키 배경 -->
        <conv:CurrentBackgroundConverter x:Key="CurrentBackgroundConverter"/>
		<conv:CurrentBackgroundConverter x:Key="BackgroundConverter"/>
		<conv:CurrentSizeConverter x:Key="SizeConverter"/>
    </Window.Resources>

    <Grid Margin="20">

		<Grid.RenderTransform>
			<TranslateTransform x:Name="ShakeTransform"/>
		</Grid.RenderTransform>


		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>


		<!-- 현재 입력 -->
		<StackPanel Grid.Row="0">

            <TextBlock
				Text="{Binding Text}"
				FontSize="{Binding State, Converter={StaticResource CurrentSizeConverter}}"
				FontWeight="Bold"/>

			<TextBlock
                x:Name="CurrentModeText"
                Text="MOVE MODE"
                Foreground="White"
                FontSize="16"/>

        </StackPanel>



		<!-- 다음 입력 리스트 -->
		<ItemsControl
			x:Name="NextInputList"
			Grid.Row="2">


			<ItemsControl.ItemsPanel>

				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal"/>
				</ItemsPanelTemplate>

			</ItemsControl.ItemsPanel>



			<ItemsControl.ItemTemplate>

                <DataTemplate>

					<Border
							Background="{Binding State, Converter={StaticResource BackgroundConverter}}"
							CornerRadius="6"
							Margin="5"
							Padding="10">

						<TextBlock
							Text="{Binding Text}"
							FontSize="{Binding State, Converter={StaticResource SizeConverter}}"
							Foreground="White"
							FontWeight="Bold"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"/>

					</Border>

                </DataTemplate>

            </ItemsControl.ItemTemplate>


		</ItemsControl>

		<Grid
        x:Name="CyclePanel"
        Height="0"
        VerticalAlignment="Top"
        Margin="15,85,15,0"
        ClipToBounds="True">

			<Border
				Background="#DD1E1E1E"
				CornerRadius="10"
				Padding="10">

				<ListBox
					x:Name="CycleList"
					Background="Transparent"
					BorderThickness="0"
					Foreground="White"
					DisplayMemberPath="Name"/>

			</Border>

		</Grid>


	</Grid>
    

</Window>